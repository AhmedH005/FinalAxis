# USDA FoodData Central (free key at https://fdc.nal.usda.gov/api-key-signup.html)
# DEMO_KEY works but is rate-limited to 30 req/hour — get a real key!
EXPO_PUBLIC_USDA_API_KEY=DEMO_KEY

# Edamam Food Database — optional upgrade for broader branded food coverage
# $14/month with 30-day free trial. Register at https://developer.edamam.com/
# Leave blank to use Open Food Facts + USDA only (works great without it).
EXPO_PUBLIC_EDAMAM_APP_ID=
EXPO_PUBLIC_EDAMAM_APP_KEY=

# Time Engine API (packages/api Express server)
# Simulator: http://localhost:4000
# Physical device: use your LAN IP e.g. http://192.168.x.x:4000
# Staging/prod: full deployed URL
EXPO_PUBLIC_TIME_API_URL=http://localhost:4000
