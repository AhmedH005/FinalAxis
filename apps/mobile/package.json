{
  "name": "@axis/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "expo": "expo start --dev-client",
    "start:clean": "expo start --dev-client --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test:engines": "node ./scripts/run-engine-tests.mjs",
    "build:ios:sim": "eas build --profile development --platform ios",
    "build:ios:dev": "eas build --profile development:device --platform ios",
    "build:ios:preview": "eas build --profile preview --platform ios",
    "build:ios:prod": "eas build --profile production --platform ios"
  },
  "dependencies": {
    "@axis/theme": "workspace:*",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@supabase/supabase-js": "2.52.1",
    "@tanstack/react-query": "5.83.0",
    "date-fns": "^3.6.0",
    "expo": "^53.0.20",
    "expo-blur": "~14.1.5",
    "expo-camera": "^55.0.9",
    "expo-constants": "~17.1.6",
    "expo-dev-client": "~5.2.1",
    "expo-font": "~14.0.11",
    "expo-haptics": "~14.1.4",
    "expo-linking": "~7.1.4",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-splash-screen": "~0.30.9",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-hook-form": "^7.53.0",
    "react-native": "0.79.4",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-health": "^1.19.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "zod": "^3.22.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.0.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~9.2.0",
    "typescript": "~5.8.3"
  },
  "engines": {
    "node": ">=20.0.0 <24"
